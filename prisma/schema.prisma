generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  games         Game[]
  memberships   GameMember[]
  chatMessages  ChatMessage[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Domain: Game ───────────────────────────────────────────────

enum GameFormat {
  CHAMBER
  FIELD
}

enum GameStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Game {
  id          String     @id @default(cuid())
  name        String
  genre       String?
  setting     String?    @db.Text
  format      GameFormat @default(CHAMBER)
  playerCount Int?
  status      GameStatus @default(DRAFT)
  dates       String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  designDocSummary String? @db.Text

  characters            GameEntity[]
  relationships         Relationship[]
  plotlines             Plotline[]
  files                 GameFile[]
  chatThreads           ChatThread[]
  chatMessages          ChatMessage[]
  auditRuns             AuditRun[]
  customFieldDefinitions CustomFieldDefinition[]
  subRoleDefinitions    SubRoleDefinition[]
  briefPipelineStages   BriefPipelineStage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members GameMember[]
}

// ─── Domain: Game Members ────────────────────────────────────────

enum MemberRole {
  EDITOR
  VIEWER
}

model GameMember {
  id     String     @id @default(cuid())
  gameId String
  userId String
  role   MemberRole @default(EDITOR)
  game   Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
  @@index([userId])
}

// ─── Domain: Characters & NPCs ──────────────────────────────────

enum EntityType {
  CHARACTER
  NPC
}

enum EntityStatus {
  DRAFT
  IN_PROGRESS
  READY
}

model GameEntity {
  id          String       @id @default(cuid())
  type        EntityType   @default(CHARACTER)
  name        String
  faction     String?
  archetype   String?
  description String?      @db.Text
  status      EntityStatus @default(DRAFT)
  hasSubRoles Boolean      @default(false)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  briefVersions    BriefVersion[]
  plotlineEntities PlotlineEntity[]
  customFieldValues CustomFieldValue[]
  subRoles         SubRole[]
  briefProgress    BriefProgress?

  relationshipsFrom Relationship[] @relation("fromEntity")
  relationshipsTo   Relationship[] @relation("toEntity")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
}

// ─── Domain: Relationships (edges) ──────────────────────────────

enum RelationshipType {
  RIVALRY
  ALLIANCE
  SECRET
  DEBT
  LOVE
  FAMILY
  MENTORSHIP
  ENMITY
  OTHER
}

model Relationship {
  id            String           @id @default(cuid())
  type          RelationshipType @default(OTHER)
  description   String?          @db.Text
  intensity     Int              @default(5) // 1-10
  bidirectional Boolean          @default(true)

  fromEntityId String
  fromEntity   GameEntity @relation("fromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)

  toEntityId String
  toEntity   GameEntity @relation("toEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  plotlineId String?
  plotline   Plotline? @relation(fields: [plotlineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
  @@index([fromEntityId])
  @@index([toEntityId])
}

// ─── Domain: Plotlines ──────────────────────────────────────────

enum PlotlineType {
  POLITICAL
  PERSONAL
  MYSTERY
  ACTION
  SOCIAL
  OTHER
}

enum PlotlineStatus {
  DRAFT
  ACTIVE
  RESOLVED
}

model Plotline {
  id          String         @id @default(cuid())
  name        String
  type        PlotlineType   @default(OTHER)
  description String?        @db.Text
  status      PlotlineStatus @default(DRAFT)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  entities      PlotlineEntity[]
  relationships Relationship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
}

model PlotlineEntity {
  id         String @id @default(cuid())
  plotlineId String
  plotline   Plotline    @relation(fields: [plotlineId], references: [id], onDelete: Cascade)
  entityId   String
  entity     GameEntity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  role       String?

  @@unique([plotlineId, entityId])
}

// ─── Domain: Briefs ─────────────────────────────────────────────

enum BriefStatus {
  DRAFT
  REVIEW
  APPROVED
}

model BriefVersion {
  id       String      @id @default(cuid())
  version  Int         @default(1)
  status   BriefStatus @default(DRAFT)

  backstory     String? @db.Text
  personality   String? @db.Text
  goalsPublic   String? @db.Text
  goalsSecret   String? @db.Text
  relationships String? @db.Text
  mechanics     String? @db.Text
  contacts      String? @db.Text
  fullText      String? @db.Text

  entityId String
  entity   GameEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityId])
  @@unique([entityId, version])
}

// ─── Domain: Files ──────────────────────────────────────────────

enum FileCategory {
  DESIGN_DOC
  RULESET
  REFERENCE
  EXPORT
}

model GameFile {
  id          String       @id @default(cuid())
  name        String
  url         String?
  mimeType    String?
  size        Int?
  category    FileCategory @default(REFERENCE)
  description String?      @db.Text
  content     Bytes?

  extractedText String? @db.Text

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([gameId])
}

// ─── Domain: Audit ──────────────────────────────────────────────

model AuditRun {
  id        String         @id @default(cuid())
  gameId    String
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  findings  AuditFinding[]
  summary   String?
  createdAt DateTime       @default(now())

  @@index([gameId])
}

model AuditFinding {
  id          String  @id @default(cuid())
  type        String
  severity    String
  description String  @db.Text
  suggestion  String  @db.Text
  entities    String[]
  resolved    Boolean @default(false)

  auditRunId String
  auditRun   AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

// ─── Domain: Chat ───────────────────────────────────────────────

model ChatThread {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")

  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  messages  ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id      String   @id @default(cuid())
  role    ChatRole
  content String   @db.Text

  threadId String
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  actions ChatAction[]

  createdAt DateTime @default(now())

  @@index([gameId])
  @@index([threadId])
}

enum ActionStatus {
  PENDING
  APPLIED
  FAILED
  UNDONE
}

model ChatAction {
  id         String       @id @default(cuid())
  messageId  String
  message    ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  actionType String
  actionId   String
  payload    Json
  status     ActionStatus @default(PENDING)
  result     Json?
  createdAt  DateTime     @default(now())
  appliedAt  DateTime?

  @@index([messageId])
}

// ─── Feature 1: Custom Fields ──────────────────────────────────

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  MULTI_SELECT
  DATE
  BOOLEAN
  URL
}

model CustomFieldDefinition {
  id          String    @id @default(cuid())
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  fieldType   FieldType
  description String?
  isRequired  Boolean   @default(false)
  sortOrder   Int       @default(0)

  options        CustomFieldOption[]
  values         CustomFieldValue[]

  entityCategory String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([gameId, slug])
  @@index([gameId])
}

model CustomFieldOption {
  id           String   @id @default(cuid())
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  label        String
  color        String?
  sortOrder    Int      @default(0)

  selectedBy   CustomFieldValueOption[]

  @@index([definitionId])
}

model CustomFieldValue {
  id           String   @id @default(cuid())
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  characterId  String
  character    GameEntity @relation(fields: [characterId], references: [id], onDelete: Cascade)

  textValue    String?
  numberValue  Float?
  booleanValue Boolean?
  dateValue    DateTime?
  selectedOptions CustomFieldValueOption[]

  @@unique([definitionId, characterId])
  @@index([characterId])
}

model CustomFieldValueOption {
  id        String   @id @default(cuid())
  valueId   String
  value     CustomFieldValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  optionId  String
  option    CustomFieldOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([valueId, optionId])
}

// ─── Feature 2: Simplified SubRoles ────────────────────────────

model SubRoleDefinition {
  id        String @id @default(cuid())
  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name      String
  slug      String
  sortOrder Int    @default(0)

  subRoles  SubRole[]

  @@unique([gameId, slug])
  @@index([gameId])
}

model SubRole {
  id              String @id @default(cuid())
  characterId     String
  character       GameEntity @relation(fields: [characterId], references: [id], onDelete: Cascade)

  definitionId    String
  definition      SubRoleDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  notes           String? @db.Text

  @@unique([characterId, definitionId])
  @@index([characterId])
}

// ─── Feature 5: Brief Pipeline (status tracking) ──────────────

enum StageType {
  KANBAN_COLUMN
  CHECKBOX
}

model BriefPipelineStage {
  id        String    @id @default(cuid())
  gameId    String
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name      String
  slug      String
  color     String    @default("#6b7280")
  sortOrder Int       @default(0)

  stageType StageType @default(KANBAN_COLUMN)
  isFinal   Boolean   @default(false)

  currentFor BriefProgress[] @relation("CurrentStage")
  checkboxes BriefCheckbox[]

  @@unique([gameId, slug])
  @@index([gameId])
}

model BriefProgress {
  id             String  @id @default(cuid())
  characterId    String  @unique
  character      GameEntity @relation(fields: [characterId], references: [id], onDelete: Cascade)

  currentStageId String?
  currentStage   BriefPipelineStage? @relation("CurrentStage", fields: [currentStageId], references: [id])

  checkedStages  BriefCheckbox[]

  notes          String? @db.Text
  lastMovedAt    DateTime?
}

model BriefCheckbox {
  id         String @id @default(cuid())
  progressId String
  progress   BriefProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  stageId    String
  stage      BriefPipelineStage @relation(fields: [stageId], references: [id])
  checked    Boolean @default(false)
  checkedAt  DateTime?

  @@unique([progressId, stageId])
}
