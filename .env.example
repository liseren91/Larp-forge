DATABASE_URL="postgresql://user:password@host:5432/larpforge?sslmode=require"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google Cloud Console -> OAuth 2.0 Client (Web application)
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: enable email provider only when SMTP is configured.
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@larpforge.app"

AI_SERVICE_URL="http://localhost:8000"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Comma-separated list of emails that have admin access (impersonation, user list)
ADMIN_EMAILS=""
